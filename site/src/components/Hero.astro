---
import TerminalDemo from "./TerminalDemo.astro";
---

<section class="relative overflow-hidden pt-14 pb-20 sm:pt-24 sm:pb-28">
  <div class="grid-bg absolute inset-0 -z-10" aria-hidden="true"></div>
  <div class="glow-orb -top-20 -left-20 h-80 w-80 bg-[var(--color-accent)]" aria-hidden="true" style="animation: pulse-glow 6s ease-in-out infinite;"></div>
  <div class="glow-orb top-10 -right-32 h-96 w-96 bg-[var(--color-info)] opacity-15" aria-hidden="true" style="animation: pulse-glow 8s ease-in-out infinite 1s;"></div>

  <div class="container-page relative">
    <div class="mx-auto max-w-3xl text-center animate-fade-up">
      <div class="mb-6 flex justify-center">
        <div class="relative">
          <div
            class="absolute inset-0 -z-10 blur-2xl opacity-60"
            style="background: radial-gradient(circle at 50% 50%, rgba(124,255,160,0.35), transparent 70%);"
            aria-hidden="true"
          ></div>
          <img src="/logo.svg" alt="squad-kit" width="88" height="88" class="h-20 w-20 sm:h-24 sm:w-24" />
        </div>
      </div>
      <a
        href="https://www.npmjs.com/package/squad-kit"
        target="_blank"
        rel="noopener"
        class="chip group !rounded-full mb-6 hover:!border-[var(--color-accent)] transition-colors"
      >
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-accent)] opacity-75"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
        </span>
        v0.9.1 · on npm
        <svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>

      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight">
        <span class="gradient-text">Plan once,</span><br />
        <span class="gradient-text">execute cheap.</span>
      </h1>

      <p class="mt-6 text-base sm:text-lg text-[var(--color-text-muted)] leading-relaxed max-w-2xl mx-auto">
        A 3-step SDD workflow CLI for AI coding agents. Your strongest model plans once — now directly
        from the terminal — and a cheap model executes many times. Prompt caching on every planning run
        cuts billed input tokens ~70% on typical sessions; tracker fetch, secrets split, and
        <code class="font-mono text-[var(--color-text)]">squad doctor</code> round out 0.2+.
      </p>

      <p class="text-sm text-[var(--color-text-muted)] mt-3 max-w-2xl mx-auto">
        Now with a visual console: <code class="kbd">npx squad-kit console</code>
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/docs/getting-started" class="btn-primary">
          Get started
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </a>
        <a href="https://github.com/AzmSquad/Squad-Kit" target="_blank" rel="noopener" class="btn-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0C17 4.7 18 5 18 5c.6 1.6.2 2.8 0 3.2a4.5 4.5 0 0 1 1.3 3.1c0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3" />
          </svg>
          Star on GitHub
        </a>
      </div>

      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs text-[var(--color-text-dim)]">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
          Node 18+
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
          MIT licensed
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
          Works with Claude Code · Cursor · Copilot · Gemini
        </span>
      </div>
    </div>

    <div class="mt-14 sm:mt-20 mx-auto max-w-3xl animate-fade-up" style="animation-delay: 0.1s;">
      <TerminalDemo />
    </div>
  </div>
</section>
