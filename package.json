{
  "name": "squad-kit",
  "version": "0.8.0",
  "author": "Momen Yasser <momenysr@gmail.com>",
  "description": "Plan once, execute cheap. A token-efficient, 3-step SDD workflow CLI (stories → plans → implementation).",
  "keywords": [
    "sdd",
    "spec-driven-development",
    "ai-agents",
    "claude-code",
    "cursor",
    "copilot",
    "planning",
    "llm"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "squad": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm run build:ui && pnpm run build:cli && pnpm run verify:console",
    "build:cli": "tsup",
    "build:ui": "pnpm -C console-ui install --no-frozen-lockfile && pnpm -C console-ui build",
    "clean": "rimraf dist console-ui/dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "verify:console": "tsx scripts/verify-console-build.ts",
    "verify:models": "tsx scripts/verify-models.ts",
    "size:guard": "tsx scripts/size-guard.ts",
    "eval": "SQUAD_INTEGRATION_TEST=1 tsx test/eval/run-eval.ts",
    "eval:offline": "tsx test/eval/run-eval-offline.ts",
    "prepublishOnly": "pnpm run verify:models && pnpm build && pnpm test && pnpm size:guard"
  },
  "dependencies": {
    "@ai-sdk/provider": "1.1.3",
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/openai": "^1.3.24",
    "@hono/node-server": "^1.13.0",
    "@inquirer/prompts": "^7.2.0",
    "boxen": "^8.0.1",
    "ai": "^4.3.19",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "fs-extra": "^11.2.0",
    "gradient-string": "^3.0.0",
    "hono": "^4.6.0",
    "ignore": "^6.0.2",
    "js-yaml": "^4.1.0",
    "kleur": "^4.1.5",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/gradient-string": "^1.1.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AzmSquad/squad-kit"
  },
  "homepage": "https://github.com/AzmSquad/squad-kit#readme",
  "bugs": {
    "url": "https://github.com/AzmSquad/squad-kit/issues"
  }
}
